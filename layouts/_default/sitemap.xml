{{- /* カスタム sitemap.xml
     除外対象:
       - タグページのうち記事2件以下（noindex, follow 対象と同一条件）
       - robotsNoIndex: true が設定されたページ
*/ -}}
{{- printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML }}
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
  xmlns:xhtml="http://www.w3.org/1999/xhtml">
  {{- range .Data.Pages }}
  {{- $isThinTag := and (eq .Kind "term") (eq .Data.Plural "tags") (lt (len .Pages) 3) }}
  {{- $isNoIndex := .Params.robotsNoIndex }}
  {{- if not (or $isThinTag $isNoIndex) }}
  <url>
    <loc>{{ .Permalink }}</loc>
    {{- if not .Lastmod.IsZero }}
    <lastmod>{{ .Lastmod.Format "2006-01-02T15:04:05-07:00" | safeHTML }}</lastmod>
    {{- end }}
  </url>
  {{- end }}
  {{- end }}
</urlset>
